{
  "name": "config-git-with-token-action",
  "version": "2.0.13",
  "description": "This GitHub Action configures git and gh to act as the user or bot behind a GitHub token.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CatChen/config-git-with-token-action.git"
  },
  "author": "Cat Chen",
  "homepage": "https://github.com/CatChen/config-git-with-token-action#readme",
  "bugs": {
    "url": "https://github.com/CatChen/config-git-with-token-action/issues"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && yarn tsc",
    "bundle": "rm -rf bundle && yarn ncc build src/index.ts --source-map --license licenses.txt --out bundle",
    "format": "prettier --write .",
    "lint": "eslint -c eslint.config.js",
    "postpublish": "pinst --enable",
    "prepare": "is-ci || husky",
    "prepublishOnly": "pinst --disable && yarn build",
    "preversion": "yarn && yarn build && yarn bundle",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/core": "^7.0.0",
    "graphql": "^16.11.0",
    "token-who-am-i-action": "^2.0.16"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.5",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.3.2",
    "pinst": "^3.0.0",
    "prettier": "^3.0.2",
    "prettier-plugin-package": "^2.0.0",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.0.0"
  },
  "types": "dist/index.d.js",
  "funding": "https://github.com/CatChen/config-git-with-token-action?sponsor=1",
  "lint-staged": {
    "*.{ts,js}": [
      "yarn format",
      "yarn lint --fix"
    ],
    "*.{json,yml,yaml,md,markdown}": "yarn format"
  },
  "packageManager": "yarn@4.13.0"
}
